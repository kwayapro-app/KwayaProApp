rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isTenantMember(choirId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/choir_memberships/$(choirId + '_' + request.auth.uid));
    }

    function getMembershipData(choirId) {
      return get(/databases/$(database)/documents/choir_memberships/$(choirId + '_' + request.auth.uid)).data;
    }

    function hasRole(choirId, role) {
      return isTenantMember(choirId) && getMembershipData(choirId).role == role;
    }

    function hasAnyRole(choirId, roles) {
      return isTenantMember(choirId) && getMembershipData(choirId).role in roles;
    }

    function hasPermission(choirId, permission) {
      return isTenantMember(choirId) && permission in getMembershipData(choirId).permissions;
    }

    // CHORISTER AUDIT FIX: PermissionChecker (permission_checker.dart) grants
    // canUploadAudio/canPlanPrograms to isManagement OR a member holding the
    // named granular permission, and planner_screen.dart actually gates its
    // create-program UI on canPlanPrograms — but the songs/song_sections/
    // audio_parts/song_programs write rules below previously checked role
    // only, never the permission. A chorister granted these permissions saw
    // working UI that always failed server-side. These mirror
    // PermissionChecker's own OR so a permission grant actually works.
    function canUploadAudio(choirId) {
      return hasAnyRole(choirId, ['leader', 'director']) || hasPermission(choirId, 'audio_uploader');
    }

    function canPlanPrograms(choirId) {
      return hasAnyRole(choirId, ['leader', 'director']) || hasPermission(choirId, 'song_program_planner');
    }

    // score_librarian was granted client-side (PermissionChecker
    // .canManageScores) and in storage.rules, but firestore.rules had no
    // score_attachments collection at all — confirmed live that even the
    // Leader was denied (fell through to the deny-all default). Mirrors
    // canUploadAudio's role-or-permission shape.
    function canManageScores(choirId) {
      return hasAnyRole(choirId, ['leader', 'director']) || hasPermission(choirId, 'score_librarian');
    }

    // SECURITY FIX (Leader/Director audit, Findings #1/#2): role: 'director'
    // alone used to be sufficient for hasAnyRole(...,['leader','director'])
    // everywhere, with no link back to which session the grant was actually
    // for — confirmed live that a guest director could create/update a
    // DIFFERENT session than the one they were invited to, and that their
    // access never expired since nothing ever cleared the membership doc.
    // functions/src/index.ts now stamps directorSessionId on every director
    // grant (guest-link or direct Leader assignment) and reverts it when the
    // session ends. Session-scoped actions (rehearsal_sessions, attendance)
    // now require the specific resource's sessionId to match this field,
    // instead of accepting the role for any session in the choir.
    function isSessionDirector(choirId, sessionId) {
      return hasRole(choirId, 'director') &&
        getMembershipData(choirId).get('directorSessionId', '') == sessionId;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // PHASE 3 FIX 5 (narrowly-scoped rules change, called out explicitly per
    // PHASE_3_REPORT.md — same review discipline as Phase 2): the freemium
    // 3-song cap was previously enforced only client-side
    // (SongRepository.isAtSongLimit), so any direct Firestore write bypassed
    // it entirely. This mirrors that check server-side in the songs create
    // rule below. NOTE: this does not fix the check-then-act race between
    // this read and SongRepository.incrementSongCount's separate,
    // non-transactional write (see PRODUCTION_READINESS_AUDIT.md §1) — that
    // needs a transactional create flow, out of scope for a rules-only fix.
    function choirData(choirId) {
      return get(/databases/$(database)/documents/choirs/$(choirId)).data;
    }

    function isUnderSongLimit(choirId) {
      return choirData(choirId).plan == 'pro' || choirData(choirId).songCount < 3;
    }

    // PRE-EXISTING BUG FIX (discovered during Phase 2 emulator testing, unrelated
    // to Fix 1/2/3 but required for the rules file to compile at all): `let` is
    // only valid inside a function body per Firestore Rules docs
    // (firebase.google.com/docs/firestore/security/rules-structure) — it cannot
    // be declared directly inside a `match` block as the old attendance rule did.
    // Replaced with this helper function, used inline below.
    //
    // CHORISTER AUDIT FIX (confirmed live: both a chorister's own RSVP write
    // and a leader marking someone's attendance returned PERMISSION_DENIED —
    // attendance was completely non-functional). Attendance document IDs are
    // `${sessionId}_${userId}` (see AttendanceIds.compositeId,
    // attendance_ids.dart) — this function's old `.split('_')[0]` therefore
    // returned the sessionId, not a choirId, so every hasPermission/hasAnyRole
    // check below was evaluating against a bogus tenant and always failed.
    // Attendance docs carry no choirId field of their own, so this derives it
    // via the parent rehearsal_sessions doc instead of misparsing the ID.
    function attendanceSessionId(attendanceId) {
      return attendanceId.split('_')[0];
    }

    function attendanceChoirId(attendanceId) {
      return get(/databases/$(database)/documents/rehearsal_sessions/$(attendanceSessionId(attendanceId))).data.choirId;
    }

    // True when {attendanceId} is the caller's own record for that session —
    // used to allow self-service RSVP without a choirId lookup.
    function isOwnAttendanceRecord(attendanceId) {
      return isAuthenticated() &&
        attendanceId == attendanceSessionId(attendanceId) + '_' + request.auth.uid;
    }

    // Users
    match /users/{userId} {
      // SECURITY-SENSITIVE CHANGE — see PHASE_2_REPORT.md "Fix 2" for the
      // functional trade-off this introduces (choir member-list/attendance/
      // member-detail screens lose live name/photo lookups for OTHER users;
      // a proper fix requires denormalizing name/photo onto choir_memberships
      // and is out of scope for this rules-only phase).
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if isOwner(userId);
    }

    // Choirs
    match /choirs/{choirId} {
      // NOTE: invite-code lookup and uniqueness-checking (previously
      // client-side `where('inviteCode', ...)` queries, which do not fit
      // this rule — see choir_memberships comment above for why a
      // field-filtered query can't be authorized by a rule keyed on
      // isTenantMember) now go through the lookupChoirByInviteCode /
      // checkInviteCodeAvailable Cloud Functions (functions/src/index.ts),
      // which use the Admin SDK to bypass rules and return only the
      // minimal fields the join UI needs. An earlier version of this rule
      // used `allow read: if isAuthenticated()` to unblock those queries
      // directly — that was rejected on review: it lets any signed-in user
      // list the entire choirs collection, dumping every choir's invite
      // code, not just the one being looked up. Keep this tenant-scoped.
      allow read: if isTenantMember(choirId);
      // Tightened alongside the choir_memberships create fix below: a choir's
      // self-declared leaderId must actually be the requester, since the
      // choir_memberships create rule trusts choirs/{choirId}.leaderId via
      // getAfter() to authorize a self-assigned 'leader' membership.
      allow create: if isAuthenticated() &&
        request.resource.data.leaderId == request.auth.uid;
      // SECURITY FIX (Leader/Director audit, Finding #2): this used to be
      // hasAnyRole(choirId, ['leader','director']) — confirmed live that a
      // guest director could rename the choir and edit its profile,
      // directly contradicting the guest-director screen's own promised
      // "cannot access: choir admin settings", and that a director could
      // also tamper with `plan`/`inviteCode` directly. Choir profile
      // management is Leader-only per PRD §5.2/§4.1 — nothing in the PRD
      // lists it as a Director capability. The one carve-out: SongRepository
      // .createSong/decrementSongCount increments/decrements `songCount` as
      // part of the same transaction as a song create/delete (see
      // song_repository.dart) — that's legitimately tied to canUploadAudio,
      // not choir-admin, so it stays scoped to exactly that one field via
      // diff().affectedKeys() rather than reopening the whole document.
      allow update: if hasRole(choirId, 'leader') ||
        (canUploadAudio(choirId) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['songCount']));
      allow delete: if hasRole(choirId, 'leader');
    }

    // Choir Memberships
    match /choir_memberships/{membershipId} {
      // NOTE: must reference resource.data fields (not the membershipId doc-ID
      // shape) because ChoirRepository.watchUserMemberships/watchMembers run
      // collection queries filtered by the `userId`/`choirId` fields
      // (choir_providers.dart) rather than doc-ID gets. Firestore can only
      // authorize a query when its rule is expressible purely in terms of
      // resource.data + request.auth — a rule keyed off the doc ID string
      // (membershipId.split('_')) is unprovable for a field-filtered query
      // and Firestore rejects the whole query with permission-denied, even
      // though every individual doc it would return actually satisfies the
      // intended access policy. This was the root cause of onboarding never
      // reaching /home: the router redirect reads userChoirsProvider, whose
      // underlying query hit this exact case.
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid ||
         isTenantMember(resource.data.choirId));

      // FIX (Phase 2, item 4): self-serve creation may only ever grant the
      // caller 'chorister' for themselves. 'leader' may only be self-granted
      // when it corresponds to a choir the same request is creating (or that
      // already exists) with leaderId == the requester, verified via
      // getAfter() against the choirs/{choirId} document in the same
      // transaction/batch. 'director' can NEVER be self-granted via create —
      // promotion to director must go through an existing leader/director's
      // update (see the update rule below). This closes the self-elevation
      // hole where any user could create their own membership with
      // role: 'director'.
      //
      // KNOWN REGRESSION: this also blocks the current guest-director
      // "join via link" flow (ChoirRepository.addGuestDirector, called from
      // app_router.dart's _RehearsalInviteScreen), which self-creates a
      // membership with role: 'director' for the invited guest. There is no
      // rules-only way to distinguish that legitimate case from the
      // vulnerability, because ChoirMembership documents carry no reference
      // back to the originating rehearsal session/guest token. See
      // PHASE_2_REPORT.md for the recommended fix (move guest-director
      // grants server-side into a Cloud Function using the Admin SDK, which
      // bypasses these rules entirely and can validate guestTokenExpiry at
      // the moment of grant).
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid &&
        (
          request.resource.data.role == 'chorister' ||
          (request.resource.data.role == 'leader' &&
            getAfter(/databases/$(database)/documents/choirs/$(request.resource.data.choirId)).data.leaderId == request.auth.uid)
        );

      // FIX (Phase 2, item 4 continued): self-updates by the membership
      // owner may not change their own role or permissions — otherwise the
      // create-time restriction above is trivially bypassed by updating
      // instead of creating.
      //
      // SECURITY FIX (Leader/Director audit, Finding #3): the second branch
      // used to be a bare hasAnyRole(choirId, ['leader','director']) with no
      // restriction on which fields could change or whose document was being
      // written — confirmed live via the emulator that (a) a director could
      // update their OWN document to set role: 'leader', and (b) a director
      // (not the Leader) could grant an arbitrary permission, or even
      // promote a different member straight to 'leader'. PRD §4.2's
      // guardrail is explicit: "Only the Choir Leader can grant or revoke
      // granular permissions. Directors cannot delegate permissions to
      // choristers... never delegatable under any circumstance." `role` is
      // now immutable through this client-facing rule entirely — every
      // legitimate role transition (chorister joining, guest/assigned
      // director grants, director-session expiry) goes through either the
      // create rule above or an Admin SDK Cloud Function
      // (joinAsGuestDirector / onRehearsalSessionDirectorChanged /
      // checkGuestTokenExpiry in functions/src/index.ts), both of which
      // bypass these rules. The Leader may still update ANOTHER member's
      // `permissions` (granting/revoking granular permissions, per PRD) and
      // `defaultVoicePart` (member_detail_screen.dart's voice-part change,
      // per PRD §5.2) — never their own, and never `role` or the
      // director-grant bookkeeping fields, which only the Cloud Functions
      // above may touch.
      allow update: if isAuthenticated() &&
        (
          (request.auth.uid == resource.data.userId &&
           request.resource.data.role == resource.data.role &&
           request.resource.data.permissions == resource.data.permissions &&
           request.resource.data.get('directorSessionId', null) == resource.data.get('directorSessionId', null) &&
           request.resource.data.get('directorPriorRole', null) == resource.data.get('directorPriorRole', null) &&
           request.resource.data.get('directorPriorPermissions', null) == resource.data.get('directorPriorPermissions', null)) ||
          (hasRole(resource.data.choirId, 'leader') &&
           request.auth.uid != resource.data.userId &&
           request.resource.data.role == resource.data.role &&
           request.resource.data.get('directorSessionId', null) == resource.data.get('directorSessionId', null) &&
           request.resource.data.get('directorPriorRole', null) == resource.data.get('directorPriorRole', null) &&
           request.resource.data.get('directorPriorPermissions', null) == resource.data.get('directorPriorPermissions', null))
        );
      allow delete: if hasRole(resource.data.choirId, 'leader');
    }

    // Songs
    match /songs/{songId} {
      allow read: if isTenantMember(resource.data.choirId);
      allow create: if isTenantMember(request.resource.data.choirId) &&
        canUploadAudio(request.resource.data.choirId) &&
        isUnderSongLimit(request.resource.data.choirId);
      allow update: if isTenantMember(resource.data.choirId) &&
        canUploadAudio(resource.data.choirId);
      // Deletion stays role-only (not permission-gated) — matches
      // PermissionChecker.canDeleteSongs, which is leader/director only with
      // no audio_uploader escape hatch, unlike upload/edit.
      allow delete: if isTenantMember(resource.data.choirId) &&
        hasAnyRole(resource.data.choirId, ['leader', 'director']);
    }

    // Song Sections
    match /song_sections/{sectionId} {
      allow read: if isTenantMember(resource.data.choirId);
      allow create: if isTenantMember(request.resource.data.choirId) &&
        canUploadAudio(request.resource.data.choirId);
      allow update: if isTenantMember(resource.data.choirId) &&
        canUploadAudio(resource.data.choirId);
      allow delete: if isTenantMember(resource.data.choirId) &&
        hasAnyRole(resource.data.choirId, ['leader', 'director']);
    }

    // Audio Parts
    match /audio_parts/{partId} {
      allow read: if isTenantMember(resource.data.choirId);
      allow create: if isTenantMember(request.resource.data.choirId) &&
        canUploadAudio(request.resource.data.choirId);
      allow update: if isTenantMember(resource.data.choirId) &&
        canUploadAudio(resource.data.choirId);
      allow delete: if isTenantMember(resource.data.choirId) &&
        hasAnyRole(resource.data.choirId, ['leader', 'director']);
    }

    // Rehearsal Sessions
    //
    // SECURITY FIX (Leader/Director audit, Finding #2): create/update used to
    // accept ANY director in the choir — confirmed live that a guest
    // director could create/update a session other than the one they were
    // invited to. Scheduling a NEW rehearsal is Leader-only (the app has no
    // client flow where a director schedules one — see PHASE reports and
    // rehearsals_screen.dart); updating an EXISTING session is scoped to the
    // specific director assigned to THAT session via isSessionDirector,
    // which checks directorSessionId rather than the bare role.
    match /rehearsal_sessions/{sessionId} {
      allow read: if isTenantMember(resource.data.choirId);
      // FUNCTIONAL FIX (Leader/Director on-device audit, task #29):
      // confirmed live that an assigned Director tapping "Schedule Session"
      // (rehearsals_screen.dart — the FAB and empty-state copy are both
      // shown to Directors with no role gating, and the build spec
      // explicitly says this FAB is "Director + Leader only") got a
      // silent PERMISSION_DENIED — the create rule only ever checked
      // 'leader'. hasAnyRole(...,'director') here is the permanent
      // assigned-director role, distinct from isSessionDirector below
      // (which is the guest-director's temporary, session-scoped grant).
      allow create: if hasAnyRole(request.resource.data.choirId, ['leader', 'director']);
      allow update: if hasRole(resource.data.choirId, 'leader') ||
        isSessionDirector(resource.data.choirId, sessionId);
      allow delete: if hasRole(resource.data.choirId, 'leader');
    }

    // Attendance
    match /attendance/{attendanceId} {
      // CHORISTER AUDIT FIX: confirmed live that this whole collection was
      // more restrictive than the app actually needs. Two separate problems:
      // (1) rehearsals_screen.dart's rsvpCountsProvider queries ALL
      // attendance docs for a session (`where('sessionId', ...)`) with no
      // role gating — it's shown to every member, not just management — so
      // read access needs to be tenant-wide, not self-or-manager-only, to
      // match what the UI already assumes. (2) watchMyRSVP does a
      // `.doc(id).snapshots()` on a record that may not exist yet (before a
      // member's first-ever RSVP); confirmed live that referencing
      // resource.data on a nonexistent document evaluates to `resource ==
      // null`, and any condition dereferencing resource.data.* on that
      // fails closed (denied) rather than "allowed, nothing there yet" —
      // isOwnAttendanceRecord sidesteps this since it only parses the
      // document ID, never resource.data. isTenantMember(resource.data
      // .choirId) is safe for the query case specifically because a query
      // only ever returns documents that already exist — resource is never
      // null there, only for a targeted single-doc read of an ID that
      // hasn't been written yet.
      // Split get/list (rather than a blanket `allow read`): confirmed live
      // that mixing isOwnAttendanceRecord (ID-string based, unrelated to
      // any resource.data field) into the same OR as
      // isTenantMember(resource.data.choirId) made Firestore reject the
      // rsvpCountsProvider *query* outright (permission-denied even for
      // docs that plainly satisfy the tenant clause) — apparently Firestore
      // requires every branch of a list rule to be resource.data-provable,
      // not just at least one. get (single-doc, always has a concrete
      // attendanceId to parse) keeps the ID-based self-check for the
      // not-yet-existing-record case; list (queries — sessionId- or
      // userId+choirId-filtered, per rehearsal_providers.dart /
      // attendance_providers.dart) uses only the resource.data clause.
      allow get: if isAuthenticated() &&
        (isOwnAttendanceRecord(attendanceId) || isTenantMember(resource.data.choirId));
      allow list: if isAuthenticated() && isTenantMember(resource.data.choirId);

      // Self-service RSVP (CHORISTER AUDIT FIX): the record's owner may
      // create/update their own doc, but may only ever set their own userId
      // and may never set `attended: true` themselves — that's a separate,
      // manager/leader-only action (marking someone present), not something
      // RSVPing should grant. `attended` must stay false (or, since
      // RehearsalRepository.setRSVP never includes it at all — seeing the
      // same resource-is-null problem as above on the read rule when it
      // tried a `.get()`-then-branch — simply absent) on create, and
      // unchanged on update.
      allow create: if isOwnAttendanceRecord(attendanceId) &&
        request.resource.data.userId == request.auth.uid &&
        (!('attended' in request.resource.data) || request.resource.data.attended == false);
      allow update: if isOwnAttendanceRecord(attendanceId) &&
        request.resource.data.userId == request.auth.uid &&
        (!('attended' in request.resource.data) || request.resource.data.attended == resource.data.attended);

      // SECURITY FIX (Leader/Director audit, Finding #2): the director
      // branch used to be hasAnyRole(...,['leader','director']) — any
      // director in the choir could mark attendance for ANY session, not
      // just the one they were assigned/invited to. Confirmed live. Now
      // scoped via isSessionDirector, matching rehearsal_sessions' update
      // rule above.
      allow write: if hasPermission(attendanceChoirId(attendanceId), 'attendance_manager') ||
        hasRole(attendanceChoirId(attendanceId), 'leader') ||
        isSessionDirector(attendanceChoirId(attendanceId), attendanceSessionId(attendanceId));
    }

    // Chat Messages
    match /chat_messages/{messageId} {
      allow read: if isTenantMember(resource.data.choirId);
      // CHORISTER AUDIT FIX: confirmed live that a chorister could write a
      // chat_messages doc with targetVoicePart set by calling the API
      // directly — the client UI correctly hides the targeting control for
      // non-management senders (chat_screen.dart's _ChatInputBar), but
      // nothing server-side backed that restriction. Voice-part targeting is
      // Director/Leader-only per the PRD, so require the field be
      // null/absent unless the sender has that role.
      //
      // FUNCTIONAL FIX (Leader/Director audit, Finding #6): PRD §4.2 grants
      // the 'announcements' permission "send targeted push to voice parts",
      // but this only ever checked hasAnyRole — confirmed live that a
      // chorister holding 'announcements' still got PERMISSION_DENIED.
      allow create: if isTenantMember(request.resource.data.choirId) &&
        (
          !('targetVoicePart' in request.resource.data) ||
          request.resource.data.targetVoicePart == null ||
          hasAnyRole(request.resource.data.choirId, ['leader', 'director']) ||
          hasPermission(request.resource.data.choirId, 'announcements')
        );
      // Same targetVoicePart restriction as create — otherwise a chorister
      // could create a message with no target, then update it to add one.
      //
      // FUNCTIONAL FIX (Leader/Director audit, Finding #7): pinning was
      // previously only possible for a message's own sender (isOwner
      // unconditionally required) — confirmed by reading chat_repository
      // .dart's pinMessage, which can target ANY message in the choir, that
      // a Director/Leader/announcements-holder pinning someone else's
      // message would hit PERMISSION_DENIED. This adds a second branch,
      // scoped via .diff().affectedKeys() (per Firestore's documented
      // "restrict updates to specific fields" pattern) to ONLY the `pinned`
      // field, so pin/unpin doesn't become a general edit escape hatch for
      // other people's messages.
      allow update: if (isOwner(resource.data.senderId) &&
          (
            !('targetVoicePart' in request.resource.data) ||
            request.resource.data.targetVoicePart == null ||
            hasAnyRole(resource.data.choirId, ['leader', 'director']) ||
            hasPermission(resource.data.choirId, 'announcements')
          )
        ) ||
        (
          (hasAnyRole(resource.data.choirId, ['leader', 'director']) ||
            hasPermission(resource.data.choirId, 'announcements')) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pinned'])
        );
      allow delete: if hasAnyRole(resource.data.choirId, ['leader', 'director']);
    }

    // Listen Events
    match /listen_events/{eventId} {
      allow read: if isAuthenticated() &&
        (request.auth.uid == resource.data.userId ||
         hasAnyRole(resource.data.choirId, ['leader', 'director']));
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid &&
        isTenantMember(request.resource.data.choirId);
      allow update, delete: if false;
    }

    // Subscriptions
    match /subscriptions/{choirId} {
      // CHORISTER AUDIT FIX: confirmed live that any tenant member (not just
      // leader/director) could read a choir's subscription/billing doc,
      // even though the UI only ever surfaces Billing to leaders
      // (home_screen.dart gates the Billing action chip on
      // PermissionChecker.isLeader). Restrict to management, matching the
      // UI's actual intent.
      allow read: if hasAnyRole(choirId, ['leader', 'director']);
      allow write: if false;
    }

    // Payment Requests
    match /payment_requests/{requestId} {
      allow read: if isTenantMember(resource.data.choirId);
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if false;
    }

    // Score Attachments
    //
    // FUNCTIONAL FIX (Leader/Director audit, Finding #5): this collection had
    // no rule at all — confirmed live that even the Leader was denied,
    // falling through to the deny-all default. score_repository.dart already
    // read/wrote score_attachments; storage.rules already had a
    // canManageScores function with a comment flagging this exact gap.
    match /score_attachments/{scoreId} {
      allow read: if isTenantMember(resource.data.choirId);
      allow create: if isTenantMember(request.resource.data.choirId) &&
        canManageScores(request.resource.data.choirId);
      allow update: if isTenantMember(resource.data.choirId) &&
        canManageScores(resource.data.choirId);
      allow delete: if isTenantMember(resource.data.choirId) &&
        canManageScores(resource.data.choirId);
    }

    // Song Programs
    match /song_programs/{programId} {
      allow read: if isTenantMember(resource.data.choirId);
      allow create: if isTenantMember(request.resource.data.choirId) &&
        canPlanPrograms(request.resource.data.choirId);
      allow update: if isTenantMember(resource.data.choirId) &&
        canPlanPrograms(resource.data.choirId);
      allow delete: if hasRole(resource.data.choirId, 'leader');
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
